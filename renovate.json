{
    "$schema": "https://docs.renovatebot.com/renovate-schema.json",
    "extends": [
        "config:base"
    ],
    "ignorePaths": ["**/.github/**"],
    "customManagers": [
        {
            "customType": "regex",
            "managerFilePatterns": [
                "^Dockerfile$"
            ],
            "matchStrings": [
                "FROM n8nio/n8n:(?<currentValue>\\d+\\.\\d+\\.\\d+)"
            ],

            "datasourceTemplate": "github-releases",
            "depNameTemplate": "n8n-io/n8n",

            "versioningTemplate": "semver-coerced",
            "extractVersionTemplate": "^n8n@(?<version>.*)$"
        }
    ],
    "packageRules": [
        {
            "matchDatasources": [
                "docker"
            ],
            "matchPackageNames": [
                "n8nio/n8n"
            ],
            "versioning": "semver",
            "automerge": true,
            "automergeType": "branch",
            "ignoreTests": true,
            "enabled": false
        }
    ]
}